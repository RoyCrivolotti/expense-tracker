{
  "name": "expense-tracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run prep:data && vite",
    "build": "npm run generate-icons && npm run prep:data && vite build",
    "prep:data": "node scripts/prep-expenses-data.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "node scripts/ensure-function-symlinks.mjs && node scripts/check-migration-docs.mjs && node scripts/check-pii.mjs && npm run lint && npm run typecheck && npm run test && npm run build && node scripts/check-bundle-budget.mjs",
    "build:staging": "npm run generate-icons && npm run prep:data && vite build --mode staging",
    "deploy": "bash scripts/deploy.sh",
    "deploy:dev": "bash scripts/deploy-dev.sh",
    "setup:dev-bindings": "node scripts/setup-dev-bindings.mjs",
    "setup:staging-project": "node scripts/setup-staging-project.mjs",
    "setup:staging-domains": "node scripts/setup-staging-domains.mjs",
    "setup:access-apps": "node scripts/setup-access-apps.mjs",
    "setup:access-migrate": "node scripts/setup-access-migrate.mjs",
    "setup:access-preview": "node scripts/setup-access-preview.mjs",
    "migrate:dev": "node scripts/migrate-dev.mjs",
    "seed:dev": "node scripts/seed-dev.mjs",
    "seed:dev-from-prod": "node scripts/seed-dev.mjs",
    "seed:demo-staging": "node scripts/seed-demo-staging.mjs",
    "seed:scenarios": "npx tsx scripts/seed-scenarios.ts",
    "deploy:backup-cron": "node scripts/deploy-backup-cron.mjs",
    "bootstrap:allowed-users": "node scripts/bootstrap-allowed-users.mjs",
    "sync:access-env": "node scripts/sync-access-env.mjs",
    "setup:access-google": "node scripts/setup-access-google.mjs",
    "setup:backups": "node scripts/setup-backup-infrastructure.mjs",
    "sync:backup-alerts": "node scripts/sync-backup-alerts.mjs",
    "capture:screenshots": "node scripts/capture-docs-screenshots.mjs",
    "verify:goals-tabs": "node scripts/verify-goals-mobile-tabs.mjs"
  },
  "dependencies": {
    "folio-shell": "^1.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.3",
    "@rolldown/binding-linux-x64-gnu": "1.0.3",
    "lightningcss-darwin-arm64": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.52.0",
    "sharp": "^0.35.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.101.0"
  }
}
