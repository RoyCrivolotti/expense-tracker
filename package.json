{
  "name": "expense-tracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run prep:data && vite",
    "build": "npm run generate-icons && npm run prep:data && vite build",
    "prep:data": "node scripts/prep-expenses-data.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "node scripts/ensure-function-symlinks.mjs && npm run lint && npm run typecheck && npm run test && npm run build",
    "deploy": "bash scripts/deploy.sh",
    "deploy:backup-cron": "node scripts/deploy-backup-cron.mjs",
    "sync:allowed-users": "node scripts/sync-allowed-users.mjs",
    "bootstrap:allowed-users": "node scripts/bootstrap-allowed-users.mjs",
    "sync:access-env": "node scripts/sync-access-env.mjs",
    "setup:access-google": "node scripts/setup-access-google.mjs",
    "setup:backups": "node scripts/setup-backup-infrastructure.mjs",
    "sync:backup-alerts": "node scripts/sync-backup-alerts.mjs",
    "capture:screenshots": "node scripts/capture-docs-screenshots.mjs"
  },
  "dependencies": {
    "@crivolotti/folio-ui": "git+https://github.com/RoyCrivolotti/folio-ui.git#v1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.52.0",
    "sharp": "^0.35.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "wrangler": "^4.101.0"
  }
}
