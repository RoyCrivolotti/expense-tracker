{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.functions.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@domain/*": ["functions/domain/*", "src/domain/*"],
      "@config/*": ["functions/config/*", "config/*"]
    },

    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["functions/**/*.ts", "src/domain/**/*.ts"],
  "exclude": ["**/*.test.ts"],
  "files": [
    "functions/api/expenses/transactions/[id].ts",
    "functions/api/expenses/categories/[id].ts",
    "functions/api/expenses/accounts/[id].ts"
  ]
}
